<Window x:Class="WarehouseNickWPF.Dialogs.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="500" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" Margin="5"/>
        <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Категория:" Margin="5"/>
        <ComboBox x:Name="CategoryComboBox" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Производитель:" Margin="5"/>
        <ComboBox x:Name="ManufacturerComboBox" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Поставщик:" Margin="5"/>
        <ComboBox x:Name="SupplierComboBox" Grid.Row="3" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Цена:" Margin="5"/>
        <TextBox x:Name="PriceTextBox" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Остаток:" Margin="5"/>
        <TextBox x:Name="StockTextBox" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Скидка %:" Margin="5"/>
        <TextBox x:Name="DiscountTextBox" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Фото:" Margin="5"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <TextBox x:Name="ImagePathTextBox" Width="200" Margin="5"/>
            <Button Content="Обзор" Click="BrowseImage_Click" Width="60" Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="OK" Click="OkButton_Click" Width="75" Margin="5"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="75" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>