<Window x:Class="WarehouseNickWPF.Dialogs.SimpleNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод названия" Height="150" Width="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock x:Name="PromptTextBlock" Text="Введите название:" Margin="0,0,0,5"/>
        <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OkButton_Click" Width="75" Margin="5"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="75" Margin="5"/>
        </StackPanel>
    </StackPanel>
</Window>