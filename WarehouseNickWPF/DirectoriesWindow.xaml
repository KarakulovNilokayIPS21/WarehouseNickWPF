<Window x:Class="WarehouseNickWPF.DirectoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочники" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">
    <TabControl Margin="10">
        <TabItem Header="Категории">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView x:Name="CategoriesListView" DisplayMemberPath="Name"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button Content="Добавить" Click="AddCategory_Click" Width="80" Margin="5"/>
                    <Button Content="Изменить" Click="EditCategory_Click" Width="80" Margin="5"/>
                    <Button Content="Удалить" Click="DeleteCategory_Click" Width="80" Margin="5"/>
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="Производители">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView x:Name="ManufacturersListView" DisplayMemberPath="Name"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button Content="Добавить" Click="AddManufacturer_Click" Width="80" Margin="5"/>
                    <Button Content="Изменить" Click="EditManufacturer_Click" Width="80" Margin="5"/>
                    <Button Content="Удалить" Click="DeleteManufacturer_Click" Width="80" Margin="5"/>
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="Поставщики">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView x:Name="SuppliersListView" DisplayMemberPath="Name"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button Content="Добавить" Click="AddSupplier_Click" Width="80" Margin="5"/>
                    <Button Content="Изменить" Click="EditSupplier_Click" Width="80" Margin="5"/>
                    <Button Content="Удалить" Click="DeleteSupplier_Click" Width="80" Margin="5"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>