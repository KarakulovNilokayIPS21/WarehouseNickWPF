<Window x:Class="WarehouseNickWPF.OrganizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление складом – Организации" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Организации" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>

        <ListView Grid.Row="1" ItemsSource="{Binding Organizations}" SelectedItem="{Binding SelectedOrganization}" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding Name}" Width="400"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Добавить" Command="{Binding AddOrganizationCommand}" Width="80" Margin="5"/>
            <Button Content="Изменить" Command="{Binding EditOrganizationCommand}" Width="80" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteOrganizationCommand}" Width="80" Margin="5"/>
            <Button Content="ОК" Command="{Binding OkCommand}" Width="80" Margin="5" IsDefault="True"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>